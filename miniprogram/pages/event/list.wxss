.event-list-page {
  background-color: #FFF9F6;
  min-height: 100vh;
  box-sizing: border-box;
}

/* 自定义顶部导航栏 (对齐 Stitch 高保真 TopAppBar) */
.custom-nav-bar {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  z-index: 100;
  background-color: rgba(255, 249, 246, 0.96);
  backdrop-filter: blur(20rpx);
  display: flex;
  justify-content: space-between;
  align-items: flex-end;
  padding: 0 32rpx;
  box-sizing: border-box;
  border-bottom: 1rpx solid rgba(255, 122, 89, 0.08);
}

.custom-nav-left {
  display: flex;
  align-items: center;
}

.nav-icon-btn {
  width: 64rpx;
  height: 64rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: background-color 0.2s ease;
}

.nav-icon-btn:active {
  background-color: rgba(255, 122, 89, 0.08);
}

.nav-title {
  font-size: 38rpx;
  color: #FF7A59;
  font-family: var(--font-headline);
  font-weight: 900;
  letter-spacing: 2rpx;
}

.custom-nav-right {
  display: flex;
  align-items: center;
  padding-right: 200rpx; /* 避开微信右上角胶囊区域 */
}

.custom-nav-spacer {
  width: 100%;
}

/* Category Chips */
.category-scroll-wrapper {
  width: 100%;
  white-space: nowrap;
  padding: 0 32rpx;
  box-sizing: border-box;
}

.category-row {
  display: inline-flex;
  gap: 16rpx;
}

.category-chip {
  background-color: #FFFFFF;
  border: 1rpx solid #F2E8E4;
  border-radius: 9999rpx;
  padding: 12rpx 36rpx;
  font-size: 26rpx;
  color: #5A514E;
  font-weight: 500;
  box-shadow: 0 4rpx 12rpx rgba(255, 127, 80, 0.03);
  transition: all 0.2s ease;
}

.category-chip.active {
  background-color: #FF7A59;
  color: #FFFFFF;
  border-color: #FF7A59;
  box-shadow: 0 4rpx 16rpx rgba(255, 122, 89, 0.25);
  font-weight: bold;
}

/* Event List Card Styles */
.list-scroll {
  height: calc(100vh - 220rpx - env(safe-area-inset-bottom));
  padding-bottom: env(safe-area-inset-bottom);
}

.card-list {
  padding: 16rpx 32rpx;
  display: flex;
  flex-direction: column;
  gap: 32rpx;
}

.event-card {
  background-color: #FFFFFF;
  border-radius: 24rpx;
  overflow: hidden;
  box-shadow: 0 6rpx 18rpx rgba(255, 127, 80, 0.05);
  display: flex;
  flex-direction: column;
  box-sizing: border-box;
}

.cover-wrapper {
  position: relative;
  width: 100%;
  aspect-ratio: 16 / 9;
  overflow: hidden;
  background-color: #F2E8E4;
}

.event-cover {
  width: 100%;
  height: 100%;
}

.status-badge {
  position: absolute;
  top: 24rpx;
  left: 24rpx;
  background-color: #FFEDE9;
  color: #FF7A59;
  padding: 8rpx 20rpx;
  border-radius: 12rpx;
  font-size: 22rpx;
  font-weight: bold;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.05);
}

.status-badge.closing {
  background-color: #FFF9E5;
  color: #D97706;
}

.event-details {
  padding: 24rpx;
}

.event-title {
  color: #1E1B1A;
  font-size: 30rpx;
  line-height: 1.4;
}

.meta-row {
  margin-top: 16rpx;
}

.meta-item {
  display: flex;
  align-items: center;
}

.meta-icon {
  width: 32rpx;
  height: 32rpx;
  color: #64748B;
}

.meta-val {
  font-size: 26rpx;
  color: #64748B;
}

/* Footer & Participants overlap */
.card-footer-divider {
  height: 1rpx;
  background-color: #F2E8E4;
  width: 100%;
}

.card-footer {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.avatar-group {
  display: flex;
}

.attendee-avatar {
  border: 4rpx solid #FFFFFF;
  border-radius: 50%;
  width: 56rpx;
  height: 56rpx;
  box-sizing: border-box;
}

.participants-count {
  font-size: 24rpx;
  color: #64748B;
  font-weight: bold;
}

.register-btn {
  border-radius: 9999rpx !important;
  font-size: 24rpx !important;
  font-weight: bold !important;
  padding: 12rpx 36rpx !important;
  height: auto !important;
  line-height: 1.2 !important;
  box-shadow: 0 4rpx 12rpx rgba(255, 122, 89, 0.15);
}
