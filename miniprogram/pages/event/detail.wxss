.event-detail-page {
  background-color: var(--color-bg-page);
  padding-bottom: calc(140rpx + env(safe-area-inset-bottom));
}

.detail-cover-box {
  position: relative;
  width: 100%;
  height: 380rpx;
  border-radius: var(--radius-lg);
  overflow: hidden;
  margin-bottom: var(--spacing-16);
  box-shadow: var(--shadow-sm);
}

.detail-cover {
  width: 100%;
  height: 100%;
}

.status-tag {
  position: absolute;
  bottom: 24rpx;
  right: 24rpx;
  padding: 8rpx 20rpx;
  border-radius: var(--radius-sm);
  font-size: var(--font-size-sm);
  font-weight: var(--font-weight-medium);
  box-shadow: var(--shadow-md);
  color: var(--color-text-inverse);
}

.status-tag.status-recruiting {
  background-color: var(--color-success);
}

.status-tag.status-ongoing {
  background-color: var(--color-info);
}

.status-tag.status-ended {
  background-color: var(--color-text-secondary);
}

/* Info card details */
.main-info-card {
  padding: var(--spacing-20);
}

.info-row {
  border-bottom: 1rpx solid var(--color-border-light);
}

.info-row:last-child {
  border-bottom: none;
}

.info-icon {
  width: 64rpx;
  height: 64rpx;
  background-color: var(--color-primary-light);
  border-radius: 50%;
  flex-shrink: 0;
}

.info-icon .icon {
  width: 32rpx;
  height: 32rpx;
  color: var(--color-primary);
}

.info-content {
  line-height: var(--line-height-normal);
}

.info-val {
  font-size: var(--font-size-base);
  color: var(--color-text-primary);
}

.info-desc {
  color: var(--color-text-tertiary);
  margin-top: 2rpx;
}

.arrow-right {
  font-size: 24rpx;
}

/* Requirements */
.requirement-card {
  padding: var(--spacing-20);
}

.req-item {
  color: var(--color-text-secondary);
}

.req-text {
  color: var(--color-text-secondary);
}

.ml-8 {
  margin-left: var(--spacing-8);
}

.mr-16 {
  margin-right: var(--spacing-16);
}

/* Description card */
.paragraph {
  line-height: var(--line-height-relaxed);
  text-indent: 2em;
}

/* Attendees list */
.attendees-scroll {
  width: 100%;
  white-space: nowrap;
}

.attendees-list {
  display: inline-flex;
  padding: var(--spacing-4) 0;
}

.attendee-item {
  width: 120rpx;
  text-align: center;
  flex-shrink: 0;
}

.attendee-img {
  border: 2rpx solid var(--color-border-light);
}

.attendee-name {
  width: 100%;
  font-weight: var(--font-weight-medium);
}

.attendee-school {
  font-size: 20rpx;
  width: 100%;
}

/* Bottom bar navigation */
.bottom-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background-color: var(--color-bg-card);
  padding: var(--spacing-16) var(--spacing-32);
  box-shadow: 0 -4rpx 16rpx rgba(0, 0, 0, 0.05);
  z-index: 900;
  gap: var(--spacing-16);
}

.share-btn {
  width: 200rpx;
  flex-shrink: 0;
}

.share-btn .icon {
  width: 32rpx;
  height: 32rpx;
}

.register-cta {
  flex: 1;
}

/* Verification Modal (Design Spec 4.4) */
.modal-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background-color: var(--color-bg-mask);
  backdrop-filter: blur(8rpx);
  z-index: 1000;
}

.modal-box {
  width: 660rpx; /* 330px */
  padding: var(--spacing-32) var(--spacing-24);
  box-sizing: border-box;
  background-color: var(--color-bg-card);
  border-radius: var(--radius-lg);
  box-shadow: var(--shadow-lg);
  animation: modalFadeIn 300ms ease;
}

.modal-header {
  color: var(--color-primary);
}

.modal-body {
  line-height: var(--line-height-relaxed);
  text-align: justify;
}

@keyframes modalFadeIn {
  from {
    opacity: 0;
    transform: scale(0.9);
  }
  to {
    opacity: 1;
    transform: scale(1);
  }
}
