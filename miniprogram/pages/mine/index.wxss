.mine-page {
  background-color: var(--color-bg-page);
  padding-bottom: calc(120rpx + env(safe-area-inset-bottom));
}

/* 4.3 异常审查驳回黄牌 Banner */
.rejection-banner {
  background-color: #FFFBEB;
  border: 2rpx solid #FEF3C7;
  border-radius: var(--radius-md);
  padding: var(--spacing-16) var(--spacing-20);
}

.rejection-content .icon-warning {
  width: 32rpx;
  height: 32rpx;
}

.rejection-content {
  flex: 1;
  margin-right: var(--spacing-16);
}

.rejection-text {
  color: #D97706; /* 琥珀黄深色字 */
  line-height: var(--line-height-normal);
}

.rejection-action {
  color: #B45309;
  flex-shrink: 0;
}

/* Profile header card */
.profile-header-card {
  padding: var(--spacing-24);
}

.user-avatar {
  border: 4rpx solid var(--color-primary-light);
  box-shadow: var(--shadow-sm);
}

.user-meta {
  min-width: 0;
}

.user-nickname {
  color: var(--color-text-primary);
}

.role-tag {
  font-size: 20rpx;
  color: var(--color-primary);
  background-color: var(--color-primary-light);
  padding: 4rpx 12rpx;
  border-radius: var(--radius-sm);
  font-weight: var(--font-weight-medium);
}

.school-row {
  line-height: 1.2;
}

.verify-dot {
  font-size: 16rpx;
  margin-right: 4rpx;
}

/* Stats grid */
.stats-grid {
  padding: var(--spacing-20) 0;
  justify-content: space-around;
  align-items: center;
}

.stats-item {
  text-align: center;
  transition: opacity var(--transition-fast);
}

.stats-item:active {
  opacity: 0.7;
}

.stats-num {
  line-height: 1.1;
}

.stats-label {
  line-height: 1;
}

.stats-divider {
  width: 1rpx;
  height: 60rpx;
  background-color: var(--color-divider);
}

/* Menu card styling */
.menu-card {
  padding: 0 var(--spacing-24);
}

.menu-item {
  width: 100%;
  box-sizing: border-box;
}

.menu-item:active {
  background-color: var(--color-bg-page);
}

.menu-title {
  font-size: var(--font-size-base);
  color: var(--color-text-primary);
}

.menu-title .icon {
  width: 36rpx;
  height: 36rpx;
}

.menu-text {
  font-size: var(--font-size-base);
  color: var(--color-text-primary);
  font-weight: var(--font-weight-medium);
}

.menu-arrow {
  font-size: 24rpx;
}

.menu-status-text {
  font-weight: var(--font-weight-medium);
}

.item-divider {
  height: 1rpx;
  background-color: var(--color-border-light);
}

/* Avatar container and badges */
.avatar-container {
  width: 128rpx;
  height: 128rpx;
}

.verified-avatar-badge {
  position: absolute;
  bottom: 0;
  right: 0;
  background-color: #10B981;
  width: 36rpx;
  height: 36rpx;
  border-radius: 50%;
  border: 4rpx solid #FFFFFF;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.1);
}

.verified-status-row {
  color: #10B981;
  font-weight: bold;
}

/* Menu icons custom background */
.menu-icon-bg {
  width: 64rpx;
  height: 64rpx;
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.menu-icon-bg.bg-orange { background-color: #FFF0ED; }
.menu-icon-bg.bg-blue { background-color: #EFF6FF; }
.menu-icon-bg.bg-green { background-color: #ECFDF5; }
.menu-icon-bg.bg-red { background-color: #FEF2F2; }
.menu-icon-bg.bg-purple { background-color: #F5F3FF; }

.unread-dot-badge {
  width: 14rpx;
  height: 14rpx;
  background-color: #EF4444;
  border-radius: 50%;
  box-shadow: 0 0 8rpx rgba(239, 68, 68, 0.4);
}

/* 客服与咨询板块 */
.service-support-card {
  background: rgba(255, 122, 89, 0.05);
  border: 1rpx solid rgba(255, 122, 89, 0.15);
  border-radius: 24rpx;
  padding: 32rpx;
  margin: 0 32rpx;
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.support-icon-circle {
  width: 80rpx;
  height: 80rpx;
  background-color: #FFFFFF;
  border-radius: 50%;
  box-shadow: 0 4rpx 12rpx rgba(255, 122, 89, 0.08);
}

.support-title {
  color: #1E1B1A;
}

.support-btn {
  background-color: #FFFFFF;
  color: #FF7A59;
  border: 1rpx solid rgba(255, 122, 89, 0.2);
  border-radius: 9999rpx;
  font-size: 24rpx;
  font-weight: bold;
  padding: 12rpx 36rpx;
  height: auto;
  line-height: 1.2;
  margin: 0;
  box-shadow: 0 4rpx 12rpx rgba(255, 122, 89, 0.05);
}

.support-btn:active {
  background-color: #FFF9F6;
  opacity: 0.9;
}

/* Footer & Help */
.footer-info {
  margin-top: var(--spacing-32);
}

.ml-12 {
  margin-left: var(--spacing-12);
}

.mr-8 {
  margin-right: var(--spacing-8);
}
