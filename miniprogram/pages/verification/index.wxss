.verification-page {
  background-color: var(--color-bg-page);
  padding: var(--page-padding);
  padding-bottom: calc(140rpx + env(safe-area-inset-bottom));
  box-sizing: border-box;
}

/* Logo Header */
.brand-logo {
  width: 96rpx;
  height: 96rpx;
  border-radius: var(--radius-md);
  box-shadow: var(--shadow-sm);
  display: inline-block;
}

.banner-main-title {
  color: var(--color-text-primary);
}

.banner-sub-desc {
  color: var(--color-text-secondary);
}

/* Progress Stepper */
.stepper-box {
  position: relative;
  width: 100%;
  box-sizing: border-box;
  padding: 0 var(--spacing-8);
}

.stepper-line-base {
  position: absolute;
  top: 28rpx;
  left: 48rpx;
  right: 48rpx;
  height: 4rpx;
  background-color: var(--color-border);
  z-index: 1;
}

.stepper-line-active {
  position: absolute;
  top: 28rpx;
  left: 48rpx;
  height: 4rpx;
  background-color: var(--color-primary);
  z-index: 2;
  transition: width var(--transition-normal);
}

.stepper-items {
  position: relative;
  z-index: 10;
}

.step-item {
  width: 80rpx;
}

.step-dot {
  width: 56rpx;
  height: 56rpx;
  background-color: #FFFFFF;
  border: 4rpx solid var(--color-border);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: var(--font-size-sm);
  font-weight: var(--font-weight-bold);
  color: var(--color-text-tertiary);
  box-shadow: 0 0 0 6rpx var(--color-bg-page);
  box-sizing: border-box;
  transition: all var(--transition-fast);
}

.step-dot.active {
  background-color: var(--color-primary);
  border-color: var(--color-primary);
  color: #FFFFFF;
  box-shadow: 0 0 0 6rpx var(--color-bg-page), 0 4rpx 12rpx rgba(255, 122, 89, 0.2);
}

.step-label {
  margin-top: var(--spacing-8);
  line-height: 1;
}

/* Step 1: Form Card */
.step-form-card {
  background-color: rgba(255, 255, 255, 0.8) !important;
  backdrop-filter: blur(8px);
  border-radius: 32rpx !important;
  border: 2rpx solid rgba(226, 232, 240, 0.5);
  box-shadow: var(--shadow-sm);
  padding: 40rpx !important;
  box-sizing: border-box;
}

.card-section-title {
  color: var(--color-text-primary);
  font-size: 32rpx;
  font-weight: 700;
  padding-bottom: 12rpx;
  border-bottom: 2rpx solid rgba(226, 232, 240, 0.4);
  margin-bottom: 32rpx;
}

.input-label {
  display: block;
  font-size: 28rpx !important;
  font-weight: 500 !important;
  color: var(--color-text-primary) !important;
  margin-bottom: 16rpx !important;
}

.input-container {
  border: 2rpx solid var(--color-border);
  border-radius: 24rpx;
  padding: 0 var(--spacing-16);
  height: 96rpx;
  background-color: #FFFFFF;
  box-sizing: border-box;
  transition: border-color var(--transition-fast);
}

.input-container:focus-within {
  border-color: var(--color-primary);
  box-shadow: 0 0 0 2rpx rgba(255, 122, 89, 0.2);
}

.input-container .icon {
  width: 36rpx;
  height: 36rpx;
  color: var(--color-text-tertiary);
}

.security-notice .icon {
  width: 32rpx;
  height: 32rpx;
  color: var(--color-primary);
}

.form-input {
  color: var(--color-text-primary);
  font-weight: var(--font-weight-medium);
}

.input-arrow {
  font-size: var(--font-size-sm);
  line-height: 1;
}

/* Radio Chips */
.degree-chips {
  width: 100%;
}

.degree-chip {
  background-color: #FFFFFF;
  border: 2rpx solid var(--color-border);
  border-radius: 24rpx;
  color: var(--color-text-secondary);
  box-sizing: border-box;
  transition: all var(--transition-fast);
}

.degree-chip.active {
  border-color: var(--color-primary);
  background-color: var(--color-primary-light);
  color: var(--color-primary);
  font-weight: var(--font-weight-semibold);
}

.error-box {
  font-size: 22rpx !important;
  color: var(--color-danger);
  margin-top: 8rpx;
  margin-bottom: 8rpx;
  line-height: var(--line-height-normal);
}

/* Security notice */
.security-notice {
  line-height: var(--line-height-relaxed);
}

.security-icon {
  font-size: 28rpx;
  line-height: 1;
  margin-top: 2rpx;
}

/* Step 2: Upload cards */
.verify-card {
  background-color: #FFFFFF;
}

.upload-title {
  color: var(--color-text-primary);
}

.upload-desc {
  color: var(--color-text-secondary);
}

.upload-grid {
  width: 100%;
}

.uploaded-item,
.upload-btn-slot {
  width: 150rpx;
  height: 150rpx;
  border-radius: var(--radius-md);
  position: relative;
  box-sizing: border-box;
}

.uploaded-item {
  border: 1rpx solid var(--color-border-light);
}

.upload-preview {
  width: 100%;
  height: 100%;
  border-radius: var(--radius-md);
}

.delete-badge {
  position: absolute;
  top: -12rpx;
  right: -12rpx;
  width: 36rpx;
  height: 36rpx;
  border-radius: 50%;
  background-color: var(--color-danger);
  color: var(--color-text-inverse);
  font-size: 22rpx;
  font-weight: bold;
  box-shadow: var(--shadow-sm);
}

.upload-btn-slot {
  border: 2rpx dashed var(--color-text-tertiary);
  background-color: var(--color-bg-page);
}

.upload-btn-slot:active {
  background-color: var(--color-border-light);
}

.add-icon {
  font-size: 44rpx;
  color: var(--color-text-tertiary);
  line-height: 1;
}

.add-text {
  margin-top: 4rpx;
}

.upload-hint {
  color: var(--color-text-tertiary);
}

/* Agreement custom checkbox */
.promise-agreement {
  box-sizing: border-box;
}

.custom-checkbox {
  width: 36rpx;
  height: 36rpx;
  border: 2rpx solid var(--color-border);
  border-radius: 8rpx;
  background-color: #FFFFFF;
  box-sizing: border-box;
  flex-shrink: 0;
}

.custom-checkbox.checkbox-active {
  background-color: var(--color-primary);
  border-color: var(--color-primary);
}

.check-mark {
  color: #FFFFFF;
  font-size: 22rpx;
  font-weight: bold;
  line-height: 1;
}

.promise-text {
  line-height: var(--line-height-normal);
}

/* Bottom Actions sticky */
.bottom-action {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background-color: var(--color-bg-card);
  padding: var(--spacing-16) var(--spacing-32);
  box-shadow: 0 -4rpx 16rpx rgba(0, 0, 0, 0.05);
  z-index: 900;
}

.bottom-action .btn {
  width: 100% !important;
  height: 96rpx !important;
  white-space: nowrap !important;
  font-size: 30rpx !important;
  font-weight: 700 !important;
  padding: 0 24rpx !important;
  border-radius: 24rpx !important; /* 12px standard rounded */
  box-sizing: border-box !important;
}

.btn-arrow {
  font-size: 24rpx;
  line-height: 1;
}

.ml-8 { margin-left: var(--spacing-8); }
.mr-8 { margin-right: var(--spacing-8); }
.mt-16 { margin-top: var(--spacing-16); }
.mb-24 { margin-bottom: var(--spacing-24); }
.mb-32 { margin-bottom: var(--spacing-32); }
.pb-8 { padding-bottom: var(--spacing-8); }
.gap-12 { gap: var(--spacing-12); }
.flex-1 { flex: 1; }
.flex-2 { flex: 2; }
.flex-1-5 { flex: 1.5; }
