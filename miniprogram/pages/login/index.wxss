.login-page {
  min-height: 100vh;
  box-sizing: border-box;
  display: flex;
  flex-direction: column;
  align-items: center;
  background: linear-gradient(180deg, #FFF0ED 0%, #FFF9F6 40%, #FFF9F6 100%);
  padding: 0 64rpx;
  padding-bottom: calc(env(safe-area-inset-bottom) + 64rpx);
}

/* --- 品牌区域 --- */
.brand-area {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-top: 140rpx;
  margin-bottom: 120rpx;
}

.logo-card {
  width: 180rpx;
  height: 180rpx;
  border-radius: 44rpx;
  background: #FFFFFF;
  border: 2rpx solid #FFEBE5;
  box-shadow: 0 12rpx 36rpx rgba(255, 122, 89, 0.08);
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 48rpx;
}

.logo-img {
  width: 110rpx;
  height: 110rpx;
}

.brand-name {
  font-size: 52rpx;
  font-weight: bold;
  color: #FF7A59;
  letter-spacing: 4rpx;
  margin-bottom: 24rpx;
}

.brand-slogan {
  font-size: 28rpx;
  color: #64748B;
  letter-spacing: 2rpx;
}

/* --- 按钮操作区域 --- */
.login-actions {
  width: 100%;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 32rpx;
  margin-bottom: auto; /* 推动底部协议区域贴底 */
}

.btn-wechat {
  width: 100% !important;
  height: 100rpx;
  border-radius: 24rpx;
  background: #FF7A59;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 16rpx;
  box-shadow: 0 8rpx 24rpx rgba(255, 122, 89, 0.2);
  border: none;
  margin: 0;
  padding: 0;
  transition: opacity 0.2s ease;
}

.btn-wechat:active {
  opacity: 0.9;
}

.wechat-icon {
  width: 44rpx;
  height: 44rpx;
}

.wechat-text {
  font-size: 32rpx;
  font-weight: bold;
  color: #FFFFFF;
}

.btn-phone {
  width: 100% !important;
  height: 100rpx;
  border-radius: 24rpx;
  background: #FFFFFF;
  border: 2rpx solid #FF7A59;
  display: flex;
  align-items: center;
  justify-content: center;
  margin: 0;
  padding: 0;
  box-sizing: border-box;
  transition: background-color 0.2s ease;
}

.btn-phone:active {
  background-color: #FFF5F2;
}

.phone-text {
  font-size: 32rpx;
  font-weight: bold;
  color: #FF7A59;
}

.skip-action {
  padding: 20rpx 40rpx;
  margin-top: 12rpx;
  display: flex;
  justify-content: center;
}

.skip-text {
  font-size: 28rpx;
  color: #FF7A59;
  opacity: 0.8;
  font-weight: 500;
  border-bottom: 2rpx solid #FF7A59;
}

/* --- 协议说明区域 --- */
.agreement-bar {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  width: 100%;
  box-sizing: border-box;
  padding-bottom: 20rpx;
}

.agreement-checkbox-wrapper {
  padding: 10rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.checkbox-circle {
  width: 32rpx;
  height: 32rpx;
  border-radius: 50%;
  border: 2rpx solid #CBD5E1;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #FFFFFF;
  transition: all 0.2s ease;
}

.checkbox-circle.checked {
  border-color: #FF7A59;
  background: #FF7A59;
}

.check-mark {
  color: #FFFFFF;
  font-size: 22rpx;
  font-weight: bold;
}

.agreement-content {
  font-size: 24rpx;
  color: #64748B;
  line-height: 1.5;
}

.agreement-link {
  color: #FF7A59;
  display: inline;
}
