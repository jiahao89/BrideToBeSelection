<view class="page-container role-select-page">
  <!-- 副标题 -->
  <view class="sub-heading text-center mb-40">
    <text class="sub-desc text-sm text-secondary">请选择您在校缘的身份，确认后不可更改</text>
  </view>

  <!-- 角色卡片区域 -->
  <view class="role-cards-area">
    <!-- 我是单身 -->
    <view
      class="role-card {{selectedRole === 'single' ? 'selected' : ''}}"
      bind:tap="onSelectRole"
      data-role="single"
    >
      <!-- 装饰性光斑 -->
      <view class="card-blur-circle"></view>
      <!-- 图标 -->
      <view class="role-icon-circle">
        <view class="icon icon-heart" style="width: 52rpx; height: 52rpx; color: #FF7A59;"></view>
      </view>
      <!-- 文字 -->
      <view class="role-content">
        <text class="role-title text-bold text-lg">我是单身</text>
        <text class="role-subtitle text-sm">寻找志同道合的高校校友</text>
      </view>
      <!-- 选中指示器 -->
      <view class="selection-indicator" wx:if="{{selectedRole === 'single'}}">
        <text class="check-icon">✓</text>
      </view>
    </view>

    <!-- 我是红娘 -->
    <view
      class="role-card {{selectedRole === 'matchmaker' ? 'selected' : ''}}"
      bind:tap="onSelectRole"
      data-role="matchmaker"
    >
      <!-- 图标 -->
      <view class="role-icon-circle">
        <view class="icon icon-users" style="width: 52rpx; height: 52rpx; color: #FF7A59;"></view>
      </view>
      <!-- 文字 -->
      <view class="role-content">
        <text class="role-title text-bold text-lg">我是红娘</text>
        <text class="role-subtitle text-sm text-secondary">帮身边的单身校友牵线搭桥</text>
      </view>
      <!-- 选中指示器 -->
      <view class="selection-indicator" wx:if="{{selectedRole === 'matchmaker'}}">
        <text class="check-icon">✓</text>
      </view>
    </view>
  </view>

  <!-- 确认按钮 -->
  <view class="bottom-action safe-bottom">
    <button
      class="btn btn-gradient btn-block btn-lg"
      disabled="{{!selectedRole}}"
      bind:tap="onNext"
    >
      确认并开始认证
    </button>
  </view>
</view>
