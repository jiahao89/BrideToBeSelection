.answer-page {
  padding: 32rpx;
  background-color: #FFF9F6;
  min-height: 100vh;
  box-sizing: border-box;
}

.header-box {
  margin-bottom: 32rpx;
}

.header-subtitle {
  display: block;
  line-height: 1.6;
}

.questions-list {
  display: flex;
  flex-direction: column;
  gap: 32rpx;
}

.question-item {
  display: flex;
  flex-direction: column;
}

.q-label {
  font-size: 34rpx;
  color: #1E1B1A;
  line-height: 1.4;
}

.textarea-container {
  background-color: #FFFFFF;
  border: 1rpx solid rgba(255, 122, 89, 0.15);
  border-radius: 24rpx;
  padding: 24rpx;
  box-sizing: border-box;
  box-shadow: 0 4rpx 12rpx rgba(255, 127, 80, 0.03);
  transition: border-color 0.2s ease;
}

.textarea-container:focus-within {
  border-color: #FF7A59;
}

.input-textarea {
  width: 100%;
  height: 200rpx;
  color: #1E1B1A;
  font-size: 30rpx;
  line-height: 1.5;
}

.word-counter {
  font-size: 24rpx;
  color: #64748B;
}

.illustration-box {
  width: 100%;
  border-radius: 24rpx;
  overflow: hidden;
  box-shadow: 0 4rpx 12rpx rgba(0,0,0,0.04);
}

.illustration-img {
  width: 100%;
  height: 100%;
}

.actions-box {
  padding-bottom: calc(48rpx + env(safe-area-inset-bottom));
}
