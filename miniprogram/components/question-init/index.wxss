/* 心动问题初始化弹窗样式 */

.qi-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.7);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 9999;
}

.qi-card {
  width: 650rpx;
  background: #fff;
  border-radius: 32rpx;
  padding: 40rpx;
  box-sizing: border-box;
}

.qi-title {
  font-size: 36rpx;
  font-weight: bold;
  color: #1a1a1a;
  text-align: center;
}

.qi-subtitle {
  font-size: 26rpx;
  color: #64748B;
  line-height: 1.6;
  text-align: center;
  margin-top: 16rpx;
  margin-bottom: 32rpx;
}

.qi-question-list {
  display: flex;
  flex-direction: column;
}

.qi-question-item {
  margin-bottom: 24rpx;
}

.qi-question-label {
  font-size: 26rpx;
  color: #64748B;
  margin-bottom: 12rpx;
}

.qi-textarea {
  width: 100%;
  min-height: 100rpx;
  border: 2rpx solid #E2E8F0;
  border-radius: 16rpx;
  padding: 20rpx;
  box-sizing: border-box;
  font-size: 28rpx;
  color: #1a1a1a;
}

.qi-placeholder {
  color: #CBD5E1;
}

.qi-preset-link {
  font-size: 26rpx;
  color: #FF7A59;
  text-decoration: underline;
  text-align: center;
  margin-bottom: 32rpx;
}

.qi-submit-btn {
  width: 100%;
  height: 88rpx;
  border-radius: 24rpx;
  background: #FF7A59;
  color: #fff;
  font-size: 30rpx;
  font-weight: bold;
  display: flex;
  align-items: center;
  justify-content: center;
  border: none;
  line-height: 88rpx;
  padding: 0;
}

.qi-submit-btn[disabled] {
  background: #FFB89E;
  color: #fff;
}
