/* ============================================================
   六朝松相亲会 · 全局设计系统
   ============================================================ */

/* === Design Tokens === */
page {
  /* --- 品牌色系 (校缘珊瑚橙) --- */
  --color-primary: #FF7A59;          /* 珊瑚橙 */
  --color-primary-light: #FFF0ED;    /* 浅蜜桃粉 */
  --color-primary-lighter: #FFF9F6;  /* 蜜桃米 */
  --color-primary-dark: #E05E3C;     /* 深珊瑚橙 */

  --color-accent: #F59E0B;           /* 琥珀黄 */
  --color-accent-light: #FBBF24;
  --color-accent-lighter: #FEF3C7;

  /* --- 语义色 --- */
  --color-success: #10B981;          /* 森林绿 */
  --color-success-light: #E6F4EA;
  --color-warning: #F59E0B;          /* 琥珀黄 */
  --color-warning-light: #FFF3E0;
  --color-danger: #EF4444;           /* 警示红 */
  --color-danger-light: #FDECEA;
  --color-info: #3B82F6;
  --color-info-light: #EFF6FF;

  /* --- 中性色阶 --- */
  --color-text-primary: #2C1810;     /* 温暖深褐黑 */
  --color-text-secondary: #7A6860;   /* 温暖石板褐 */
  --color-text-tertiary: #9E8C86;    /* 温暖迷雾灰 */
  --color-text-placeholder: #9E8C86;
  --color-text-disabled: #D8C2BC;
  --color-text-inverse: #FFFFFF;

  --color-bg-page: #FFF9F6;          /* 温暖蜜桃白 */
  --color-bg-card: #FFFFFF;
  --color-bg-elevated: #FFFFFF;
  --color-bg-mask: rgba(0, 0, 0, 0.5);
  --color-bg-hover: rgba(255, 122, 89, 0.06);

  --color-border: #E2E8F0;
  --color-border-light: #F1F5F9;
  --color-divider: #ECECF2;

  /* --- 婚史"暂不披露"黄牌 --- */
  --color-undisclosed-bg: #FFF8E1;
  --color-undisclosed-border: #FFD54F;
  --color-undisclosed-text: #F57F17;

  /* --- 字体排版 --- */
  --font-family: -apple-system, BlinkMacSystemFont, 'PingFang SC',
    'Helvetica Neue', 'Microsoft YaHei', sans-serif;

  --font-size-xs: 20rpx;
  --font-size-sm: 24rpx;
  --font-size-base: 28rpx;
  --font-size-md: 30rpx;
  --font-size-lg: 32rpx;
  --font-size-xl: 36rpx;
  --font-size-2xl: 40rpx;
  --font-size-3xl: 48rpx;
  --font-size-title: 44rpx;

  --font-weight-regular: 400;
  --font-weight-medium: 500;
  --font-weight-semibold: 600;
  --font-weight-bold: 700;

  --line-height-tight: 1.25;
  --line-height-normal: 1.5;
  --line-height-relaxed: 1.75;

  /* --- 间距 --- */
  --spacing-2: 4rpx;
  --spacing-4: 8rpx;
  --spacing-8: 16rpx;
  --spacing-12: 24rpx;
  --spacing-16: 32rpx;
  --spacing-20: 40rpx;
  --spacing-24: 48rpx;
  --spacing-32: 64rpx;
  --spacing-40: 80rpx;
  --spacing-48: 96rpx;

  --page-padding: 32rpx;

  /* --- 圆角 --- */
  --radius-sm: 8rpx;
  --radius-md: 12rpx;
  --radius-lg: 24rpx;
  --radius-xl: 32rpx;
  --radius-2xl: 40rpx;
  --radius-full: 999rpx;

  /* --- 阴影 --- */
  --shadow-sm: 0 2rpx 8rpx rgba(0, 0, 0, 0.06);
  --shadow-md: 0 4rpx 16rpx rgba(0, 0, 0, 0.08);
  --shadow-lg: 0 8rpx 32rpx rgba(0, 0, 0, 0.12);
  --shadow-xl: 0 16rpx 48rpx rgba(0, 0, 0, 0.16);
  --shadow-card: 0 4rpx 12rpx rgba(255, 127, 80, 0.06);
  --shadow-elevated: 0 8rpx 24rpx rgba(255, 127, 80, 0.1);

  /* --- 动画 --- */
  --transition-fast: 150ms ease;
  --transition-normal: 250ms ease;
  --transition-slow: 350ms cubic-bezier(0.4, 0, 0.2, 1);

  /* --- 全局样式 --- */
  font-family: var(--font-family);
  font-size: var(--font-size-base);
  line-height: var(--line-height-normal);
  color: var(--color-text-primary);
  background-color: var(--color-bg-page);
}

/* ============================================================
   全局工具类
   ============================================================ */

/* --- 文本 --- */
.text-primary { color: var(--color-primary); }
.text-accent { color: var(--color-accent); }
.text-secondary { color: var(--color-text-secondary); }
.text-tertiary { color: var(--color-text-tertiary); }
.text-danger { color: var(--color-danger); }
.text-success { color: var(--color-success); }
.text-bold { font-weight: var(--font-weight-bold); }
.text-medium { font-weight: var(--font-weight-medium); }
.text-center { text-align: center; }
.text-sm { font-size: var(--font-size-sm); }
.text-lg { font-size: var(--font-size-lg); }
.text-xl { font-size: var(--font-size-xl); }

.text-ellipsis {
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.text-clamp-2 {
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

/* --- 布局 --- */
.flex { display: flex; }
.flex-col { display: flex; flex-direction: column; }
.flex-center { display: flex; align-items: center; justify-content: center; }
.flex-between { display: flex; align-items: center; justify-content: space-between; }
.flex-wrap { flex-wrap: wrap; }
.flex-1 { flex: 1; }
.items-center { align-items: center; }
.gap-8 { gap: var(--spacing-8); }
.gap-12 { gap: var(--spacing-12); }
.gap-16 { gap: var(--spacing-16); }

/* --- 间距 --- */
.p-16 { padding: var(--spacing-16); }
.p-24 { padding: var(--spacing-24); }
.px-16 { padding-left: var(--spacing-16); padding-right: var(--spacing-16); }
.py-16 { padding-top: var(--spacing-16); padding-bottom: var(--spacing-16); }
.mt-8 { margin-top: var(--spacing-8); }
.mt-16 { margin-top: var(--spacing-16); }
.mt-24 { margin-top: var(--spacing-24); }
.mb-8 { margin-bottom: var(--spacing-8); }
.mb-16 { margin-bottom: var(--spacing-16); }
.mb-24 { margin-bottom: var(--spacing-24); }

/* --- 卡片 --- */
.card {
  background: var(--color-bg-card);
  border-radius: var(--radius-lg);
  box-shadow: var(--shadow-card);
  padding: var(--spacing-24);
  margin-bottom: var(--spacing-16);
}

.card-elevated {
  background: var(--color-bg-elevated);
  border-radius: var(--radius-xl);
  box-shadow: var(--shadow-elevated);
  padding: var(--spacing-24);
}

/* ============================================================
   基础组件样式
   ============================================================ */

/* --- 按钮 --- */
.btn {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  height: 88rpx;
  padding: 0 32rpx;
  border-radius: var(--radius-lg);
  font-size: var(--font-size-md);
  font-weight: var(--font-weight-medium);
  transition: opacity var(--transition-fast), transform var(--transition-fast);
  border: none;
  outline: none;
  box-sizing: border-box;
  line-height: 1;
}

.btn::after { border: none; }

.btn:active {
  opacity: 0.85;
  transform: scale(0.97);
}

.btn-primary {
  background: linear-gradient(135deg, #FF9E84, #FF7A59);
  color: var(--color-text-inverse);
  box-shadow: 0 8rpx 24rpx rgba(255, 122, 89, 0.2);
}

.btn-accent {
  background: linear-gradient(135deg, var(--color-accent), var(--color-accent-light));
  color: var(--color-text-inverse);
  box-shadow: 0 4rpx 16rpx rgba(196, 151, 47, 0.3);
}

.btn-outline {
  background: transparent;
  color: var(--color-primary);
  border: 2rpx solid var(--color-primary);
}

.btn-ghost {
  background: var(--color-primary-lighter);
  color: var(--color-primary);
}

.btn-danger {
  background: var(--color-danger);
  color: var(--color-text-inverse);
}

.btn-block {
  display: flex;
  width: 100%;
}

.btn-sm {
  height: 64rpx;
  padding: 0 var(--spacing-20);
  font-size: var(--font-size-sm);
  border-radius: var(--radius-lg);
}

.btn-lg {
  height: 100rpx;
  font-size: var(--font-size-lg);
  border-radius: var(--radius-2xl);
}

.btn[disabled],
.btn-disabled {
  opacity: 0.45;
  pointer-events: none;
}

/* --- 认证标签 --- */
.verify-tag {
  display: inline-flex;
  align-items: center;
  height: 40rpx;
  padding: 0 var(--spacing-12);
  border-radius: var(--radius-full);
  font-size: var(--font-size-xs);
  font-weight: var(--font-weight-medium);
  gap: var(--spacing-4);
}

.verify-tag-identity {
  background: var(--color-success-light);
  color: var(--color-success);
}

.verify-tag-education {
  background: var(--color-info-light);
  color: var(--color-info);
}

.verify-tag-work {
  background: var(--color-accent-lighter);
  color: var(--color-accent);
}

.verify-tag-pending {
  background: var(--color-bg-page);
  color: var(--color-text-tertiary);
}

/* --- 婚史"暂不披露"黄牌 --- */
.undisclosed-badge {
  display: inline-flex;
  align-items: center;
  padding: var(--spacing-4) var(--spacing-12);
  background: var(--color-undisclosed-bg);
  border: 2rpx solid var(--color-undisclosed-border);
  border-radius: var(--radius-sm);
  color: var(--color-undisclosed-text);
  font-size: var(--font-size-xs);
  font-weight: var(--font-weight-semibold);
}

.undisclosed-card {
  background: var(--color-undisclosed-bg) !important;
  border: 2rpx solid var(--color-undisclosed-border);
}

/* --- 输入框 --- */
.input-group {
  margin-bottom: var(--spacing-20);
}

.input-label {
  display: block;
  font-size: var(--font-size-sm);
  font-weight: var(--font-weight-medium);
  color: var(--color-text-secondary);
  margin-bottom: var(--spacing-8);
}

.input-label .required {
  color: var(--color-danger);
  margin-left: var(--spacing-4);
}

.input-field {
  width: 100%;
  height: 88rpx;
  padding: 0 var(--spacing-16);
  background: var(--color-bg-page);
  border: 2rpx solid transparent;
  border-radius: var(--radius-lg);
  font-size: var(--font-size-base);
  color: var(--color-text-primary);
  transition: border-color var(--transition-fast);
  box-sizing: border-box;
}

.input-field:focus,
.input-field-focus {
  border-color: var(--color-primary);
  background: var(--color-primary-lighter);
}

.input-textarea {
  width: 100%;
  min-height: 200rpx;
  padding: var(--spacing-16);
  background: var(--color-bg-page);
  border: 2rpx solid transparent;
  border-radius: var(--radius-lg);
  font-size: var(--font-size-base);
  color: var(--color-text-primary);
  box-sizing: border-box;
}

/* --- 分隔线 --- */
.divider {
  height: 1rpx;
  background: var(--color-divider);
  margin: var(--spacing-16) 0;
}

/* --- 头像 --- */
.avatar {
  border-radius: 50%;
  overflow: hidden;
  background: var(--color-bg-page);
  flex-shrink: 0;
}

.avatar-sm { width: 64rpx; height: 64rpx; }
.avatar-md { width: 96rpx; height: 96rpx; }
.avatar-lg { width: 128rpx; height: 128rpx; }
.avatar-xl { width: 180rpx; height: 180rpx; }

/* --- 空状态 --- */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: var(--spacing-48) var(--spacing-32);
}

.empty-state-icon {
  width: 200rpx;
  height: 200rpx;
  margin-bottom: var(--spacing-24);
  opacity: 0.6;
}

.empty-state-text {
  font-size: var(--font-size-md);
  color: var(--color-text-tertiary);
  text-align: center;
}

/* --- 安全区域 --- */
.safe-bottom {
  padding-bottom: constant(safe-area-inset-bottom);
  padding-bottom: env(safe-area-inset-bottom);
}

/* --- 页面容器 --- */
.page-container {
  min-height: 100vh;
  padding: var(--page-padding);
  padding-bottom: calc(var(--spacing-48) + env(safe-area-inset-bottom));
  box-sizing: border-box;
}

/* --- 加载指示器 --- */
.loading-spinner {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: var(--spacing-32);
}

/* --- 里程碑标签 --- */
.milestone-tag {
  display: inline-flex;
  align-items: center;
  padding: var(--spacing-4) var(--spacing-12);
  border-radius: var(--radius-full);
  font-size: var(--font-size-xs);
  font-weight: var(--font-weight-semibold);
}

.milestone-m1 { background: #E3F2FD; color: #1565C0; }
.milestone-m2 { background: #E8F5E9; color: #2E7D32; }
.milestone-m3 { background: #FFF3E0; color: #E65100; }
.milestone-m4 { background: #FCE4EC; color: #C62828; }
.milestone-m5 { background: #F3E5F5; color: #6A1B9A; }

/* --- 全局矢量图标系统 (代替 Emoji) --- */
.icon {
  display: inline-block;
  width: 32rpx;
  height: 32rpx;
  background-color: currentColor;
  -webkit-mask-repeat: no-repeat;
  mask-repeat: no-repeat;
  -webkit-mask-position: center;
  mask-position: center;
  -webkit-mask-size: contain;
  mask-size: contain;
  vertical-align: middle;
}

